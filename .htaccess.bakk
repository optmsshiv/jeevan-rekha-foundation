RewriteEngine On

# ----------------------------------------------------------------
# 1) If someone types the .php extension directly in the URL,
#    redirect them (301) to the clean URL without it.
#    e.g. yoursite.com/about.php -> yoursite.com/about
# ----------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ----------------------------------------------------------------
# 2) Internally serve the .php file when the clean URL is requested,
#    without changing what shows in the browser's address bar.
#    e.g. yoursite.com/about -> serves about.php behind the scenes
# ----------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php [L]

# ----------------------------------------------------------------
# Homepage loads without needing "index.php" in the URL bar
# ----------------------------------------------------------------
DirectoryIndex index.php

# ----------------------------------------------------------------
# Force HTTPS
# Bluehost issues a free SSL cert (Let's Encrypt) automatically —
# once it shows Active in cPanel > SSL/TLS Status, keep this ON.
# If the site breaks right after going live, comment these 2 lines
# out temporarily until the cert finishes provisioning.
# ----------------------------------------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------------
# Force non-www (pick ONE of the two blocks below — non-www is on
# by default; comment it and uncomment the www block if you'd
# rather www.yoursite.com be canonical)
# ----------------------------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Force www:
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------------
# Block direct browser access to /includes/ (header/navbar/footer/
# config partials — these should only ever be reached via PHP
# include(), never requested directly)
# ----------------------------------------------------------------
RewriteRule ^includes/ - [F,L]

# ----------------------------------------------------------------
# Block direct browser access to /data/ (contact form submission
# log — inquiries.csv contains names/phone numbers/messages and
# must never be publicly downloadable)
# ----------------------------------------------------------------
RewriteRule ^data/ - [F,L]

# ----------------------------------------------------------------
# Custom 404 page
# ----------------------------------------------------------------
ErrorDocument 404 /404.php

# ----------------------------------------------------------------
# Disable directory listing (so /assets/img/ etc. can't be browsed)
# ----------------------------------------------------------------
Options -Indexes

# ----------------------------------------------------------------
# Correct mime types for favicon/webp — some shared-hosting Apache
# configs don't map these by default, which can make browsers
# download the file instead of displaying it.
# ----------------------------------------------------------------
<IfModule mod_mime.c>
    AddType image/x-icon .ico
    AddType image/webp .webp
</IfModule>

# ----------------------------------------------------------------
# Browser caching for static assets
# ----------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
</IfModule>

# ----------------------------------------------------------------
# Gzip compression
# ----------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/plain application/javascript text/javascript application/json image/svg+xml
</IfModule>

# ----------------------------------------------------------------
# Basic security headers
# ----------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ----------------------------------------------------------------
# Hide .htaccess itself and other dotfiles from being served
# Written to work on both Apache 2.4 (mod_authz_core) and older
# 2.2-style hosts (mod_access_compat) — using only the old syntax
# can itself trigger a 403 on some Apache 2.4 configs.
# ----------------------------------------------------------------
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
