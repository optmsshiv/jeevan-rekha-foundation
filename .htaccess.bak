RewriteEngine On

# ----------------------------------------------------------------
# 1) If someone types the .html extension directly in the URL,
#    redirect them (301) to the clean URL without it.
#    e.g. yoursite.com/page.html -> yoursite.com/page
# ----------------------------------------------------------------
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ----------------------------------------------------------------
# 2) Internally serve the .html file when the clean URL is requested,
#    without changing what shows in the browser's address bar.
#    e.g. yoursite.com/page -> serves page.html behind the scenes
# ----------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# ----------------------------------------------------------------
# Optional: force the homepage to load without needing "index.html"
# in the URL bar (usually automatic, kept here for safety)
# ----------------------------------------------------------------
DirectoryIndex index.html

# ----------------------------------------------------------------
# Optional but recommended: force HTTPS
# Uncomment the two lines below once your SSL certificate is active
# ----------------------------------------------------------------
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------------
# Optional: remove "www" (or force it) — pick ONE of the two blocks
# ----------------------------------------------------------------
# Force non-www:
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Force www:
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ----------------------------------------------------------------
# Custom 404 page (optional — create a 404.html if you want this)
# ----------------------------------------------------------------
# ErrorDocument 404 /404.html
